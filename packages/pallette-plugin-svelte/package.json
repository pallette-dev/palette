{
  "name": "@pallette/plugin-svelte",
  "version": "0.0.2",
  "license": "MIT",
  "author": "Eugene Michasiw",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "svelte": "./src/index.ts",
  "exports": {

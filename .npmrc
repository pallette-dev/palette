# prefer-workspace-packages does not rewrite resolutions already frozen in pnpm-lock.yaml;
# after changing these flags, run `pnpm install` from the repo root to re-resolve.
# Root package.json `pnpm.overrides` forces `@pallette/*` to workspace here while demos
# still declare semver (e.g. ^0.0.1) for sandboxes that install without the monorepo root.
link-workspace-packages=true
prefer-workspace-packages=true
